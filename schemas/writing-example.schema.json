{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProseKernel Writing Example",
  "type": "object",
  "required": [
    "title",
    "author",
    "source_url",
    "added",
    "category",
    "format",
    "rights",
    "tags",
    "quality_score",
    "use_when"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "date_published": {
      "type": "string"
    },
    "added": {
      "type": "string"
    },
    "category": {
      "enum": [
        "viral-social",
        "persuasive-copywriting",
        "strategic-intelligent",
        "essays-literary",
        "technical-explanatory",
        "brand-positioning",
        "email-newsletters",
        "speeches-oratory",
        "journalism-reportage",
        "ux-product-microcopy",
        "crisis-communications",
        "internal-ops-docs"
      ]
    },
    "format": {
      "type": "string"
    },
    "rights": {
      "enum": [
        "public-domain",
        "open-license",
        "short-excerpt",
        "metadata-only",
        "user-provided"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pattern_ids": {
      "type": "array",
      "items": {
        "enum": [
          "PATTERN_PROOF_001",
          "PATTERN_HOOK_001",
          "PATTERN_EMAIL_001",
          "PATTERN_CRISIS_001",
          "PATTERN_UX_001",
          "PATTERN_STRATEGY_001",
          "PATTERN_BRAND_001",
          "PATTERN_EXPLAIN_001",
          "PATTERN_SPEECH_001",
          "PATTERN_REPORTAGE_001",
          "PATTERN_INTERNAL_001",
          "PATTERN_PERSUASION_001"
        ]
      }
    },
    "quality_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "use_when": {
      "type": "string"
    }
  }
}